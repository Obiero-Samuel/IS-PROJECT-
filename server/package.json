{
  "name": "is-project-server",
  "version": "1.0.0",
  "description": "Express backend for IS PROJECT",
  "main": "server.js",
  "scripts": {
    "start": "node server.js",
    "dev": "node --watch server.js",
    "db:migrate": "node db/migrate.js migrate",
    "db:seed": "node db/migrate.js seed",
    "db:setup": "node db/migrate.js all",
    "smoke:all-pages": "node scripts/smoke_all_pages.js",
    "db:backup": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\auto_postgres_backups.ps1",
    "db:backup:dryrun": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\auto_postgres_backups.ps1 -DryRun",
    "db:backup:register": "powershell -NoProfile -ExecutionPolicy Bypass -File .\\scripts\\auto_postgres_backups.ps1 -RegisterDailyTask -TaskTime 02:00"
  },
  "keywords": [],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "bcrypt": "^5.1.1",
    "cookie-parser": "^1.4.7",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.19.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "multer": "^1.4.5-lts.1",
    "node-cron": "^3.0.3",
    "nodemailer": "^6.10.1",
    "pdfkit": "^0.15.0",
    "pg": "^8.12.0",
    "uuid": "^10.0.0"
  }
}