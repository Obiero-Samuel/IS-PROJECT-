PORT=5000
NODE_ENV=development

# Database configuration
DB_USER=postgres
DB_PASSWORD=
DB_HOST=localhost
DB_PORT=5432
DB_NAME=is_project_db

# JWT configuration
JWT_SECRET=your_super_secret_jwt_key_change_in_production
JWT_EXPIRES_IN=7d
# HttpOnly session-cookie configuration (recommended for browser auth)
AUTH_COOKIE_NAME=is_project_session
AUTH_COOKIE_MAX_AGE_MS=604800000
AUTH_COOKIE_SAMESITE=lax
# Set true when running behind HTTPS in production.
AUTH_COOKIE_SECURE=
# Frontend origins allowed to send credentialed requests (comma-separated).
CORS_ORIGINS=http://localhost:3000

# Email/OTP verification configuration
OTP_TTL_MINUTES=10
# Optional (development only): set true to include OTP in API debug payloads.
# Keep false/empty to enforce email-first verification flow.
EXPOSE_DEV_OTP=
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@example.com
SMTP_PASS=your_16_char_app_password
MAIL_FROM=IS PROJECT <your-email@example.com>

# Optional: comma-separated recipients for automated weekly analytics emails.
# If empty, system falls back to all admin user emails.
ANALYTICS_ALERT_EMAILS=
